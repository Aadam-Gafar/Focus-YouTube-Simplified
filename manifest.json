{
  "manifest_version": 3,
  "name": "Mono, a distraction-free YouTube extension",
  "version": "2.0.0",
  "description": "Reclaim your time.",
  "content_scripts": [
    {
      "css": ["styles.css"],
      "matches": ["https://www.youtube.com/*"]
    }
  ],
  "icons": {
    "128": "art/icon_128.png"
  }
}